{
  "name": "cairn-plot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "cairn-plot — the pure TS/React renderer library + self-contained standalone IIFE bundles.",
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "test": "node --experimental-strip-types --test \"src/lib/cairn-plot/**/*.test.ts\"",
    "gen:plot-schema": "node scripts/gen-plot-spec-schema.mjs",
    "check:plot-schema": "node scripts/check-plot-spec-schema.mjs",
    "check:plot-boundary": "node scripts/check-plot-boundary.mjs",
    "build:plot-inline": "vite build --config vite.plot-figure.config.ts && vite build --config vite.plot-three.config.ts && vite build --config vite.plot-gpu-image.config.ts && vite build --config vite.plot-core.config.ts",
    "sync:plot-assets": "node scripts/sync-plot-assets.mjs",
    "check:plot-assets": "node scripts/sync-plot-assets.mjs --check",
    "smoke:plot": "node scripts/smoke-plot-gallery.mjs"
  },
  "dependencies": {
    "plotly.js-dist-min": "^3.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "recharts": "^2.13.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-plotly.js": "^2.6.4",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@webgpu/types": "^0.1.71",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
