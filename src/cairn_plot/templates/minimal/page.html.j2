{#
  minimal theme — a complete standalone document with NO report theme, matching
  the historical `_full_document` shell. `<html class="cairn-plot-doc">` +
  `<meta name="color-scheme">` still opt the mounted plots into the renderer
  bundle's own light/dark token contract; the report prose stays UA-default.
#}
<!doctype html>
<html lang="en" class="cairn-plot-doc"><head><meta charset="utf-8"><meta name="color-scheme" content="light dark"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{ title | e if title else "cairn report" }}</title></head><body>
{% include "minimal/fragment.html.j2" %}
</body></html>
